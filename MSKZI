#include <cstdint>
#include <iomanip>
#include <iostream>
using namespace std;

int main(int argc, char** argv) {
    uint8_t S[16] = { 
        0x05, 0x0D, 0x0F, 0x06, 0x09, 0x02, 0x0C, 0x0A,
        0x0B, 0x07, 0x08, 0x01, 0x04, 0x03, 0x0E, 0x00
    };
    
    uint64_t a = 0x0123456789ABCDEF;
    uint8_t mass_a[16] = {0x00,0x01,0x02,0x03,0x04,0x05,0x06,0x07,0x08,0x09,0x0A,0x0B,0x0C,0x0D,0x0E,0x0F};
   
    // Подстановка по 4 бита 
    uint64_t a_zamena{ 0 };
    for(int i = 0; i < 16; i++) {
        a_zamena = a_zamena | (uint64_t)S[mass_a[i]] << (60 - 4 * i);
    }
    
    // Формирование таблицы S* для подстановки двух смежных 4-битных векторов
    uint8_t Sa[256]{ 0 };
    for(int i = 0; i < 16; i++) {
        for(int j = 0; j < 16; j++) {
            Sa[i * 16 + j] = (S[i] << 4) | S[j];
        }				
    }
    
    // Подстановка по таблице S* 
    uint64_t a_zamena2{ 0 };
    for(int i = 0; i < 8; i++) {
        uint8_t byte = (a >> (56 - 8 * i)) & 0xFF;
        a_zamena2 = a_zamena2 | (uint64_t)Sa[byte] << (56 - 8 * i);
    }
    
    // Операция перестановки с циклическим сдвигом вправо на p=5 бит 
    uint64_t sdvig{ 0 };
    int p = 5;  
    for(int i = 0; i < 8; i++) {
        uint8_t byte = (a >> (56 - 8 * i)) & 0xFF;
        byte = (byte >> p) | (byte << (8 - p));
        sdvig = sdvig | ((uint64_t)byte << (56 - 8 * i));
    }

    cout << hex << uppercase << setfill('0');
    cout << "Исходное число: 0x" << setw(16) << a << endl;
    cout << "После подстановки (п. 2.1): 0x" << setw(16) << a_zamena << endl;
    cout << "После подстановки (п. 2.2): 0x" << setw(16) << a_zamena2 << endl;
    cout << "После циклического сдвига (п. 2.3): 0x" << setw(16) << sdvig << endl;
    
    cout << "\nТаблица Sa (S*):\n";
    for(int i = 0; i < 256; i++) {
        cout << setw(2) << (int)Sa[i] << " ";
        if((i + 1) % 16 == 0)
            cout << endl;
    }
    
    return 0;
}
