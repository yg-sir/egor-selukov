#include <cstdint>
using namespace std;

uint8_t komb(uint8_t x, const uint8_t S[16], int p) {
    //Старшие 4 бита
    uint8_t x1 = x >> 4 & 0x0F;
    //Младшие 4 бита
    uint8_t x2 = x & 0x0F;
    //Подстановка
    uint8_t y1 = S[x1];
    uint8_t y2 = S[x2];
    //Объединение
    uint8_t XY = (y1 << 4) | y2;
    //циклический сдвиг
    uint8_t result = (XY >> p) | (XY << (8 - p));
    return result;
}

